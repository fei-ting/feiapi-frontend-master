{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "src/main.ts",
    "src/App.vue",
    "src/env.d.ts",
    "src/components/**/*.vue",
    "src/router/**/*.ts",
    "src/services/http.ts",
    "src/services/analysis.ts",
    "src/services/interfaceInfo.ts",
    "src/services/user.ts",
    "src/services/userInterfaceInfo.ts",
    "src/stores/**/*.ts",
    "src/styles/**/*.css",
    "src/types/**/*.ts",
    "src/views/**/*.vue"
  ],
  "exclude": [
    "src/access.ts",
    "src/app.tsx",
    "src/global.less",
    "src/global.tsx",
    "src/manifest.json",
    "src/requestConfig.ts",
    "src/service-worker.js",
    "src/typings.d.ts",
    "src/components/Footer/**",
    "src/components/HeaderDropdown/**",
    "src/components/HeaderSearch/**",
    "src/components/NoticeIcon/**",
    "src/components/RightContent/**",
    "src/pages/**",
    "src/services/ant-design-pro/**",
    "src/services/feiapi-backend/**",
    "src/services/swagger/**",
    "src/utils/loginAttemptLimiter.ts"
  ]
}
